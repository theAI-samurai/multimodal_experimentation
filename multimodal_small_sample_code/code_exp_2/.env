# Text encoder selection
# Options: simple | roberta | bert | modernbert | siglip
TEXT_ENCODER=siglip

# HuggingFace model name (ignored when TEXT_ENCODER=simple)
# roberta:    roberta-base | roberta-large | sentence-transformers/all-roberta-large-v1
# bert:       bert-base-uncased | bert-large-uncased | bert-base-cased
# modernbert: answerdotai/ModernBERT-base | answerdotai/ModernBERT-large
# siglip:     google/siglip-base-patch16-224
TEXT_ENCODER_MODEL=google/siglip-base-patch16-224

# Shared encoder settings
EMBED_DIM=256
FREEZE_BACKBONE=false
POOLING_STRATEGY=mean
